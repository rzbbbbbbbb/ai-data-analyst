# 数据库配置（本地开发用 SQLite 最方便，无需安装数据库）
DATABASE_URL=sqlite:///./data/analyst.db
# 如果要展示 PostgreSQL 能力，改成下面这样（需要本地装了PG）：
# DATABASE_URL=postgresql://user:password@localhost:5432/analyst

# OpenAI API（也支持任何兼容的 API，比如国内的 DeepSeek、Moonshot 等）
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
